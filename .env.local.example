# Stripe secret key — get this from https://dashboard.stripe.com/apikeys
# Use a "sk_test_..." key while you're testing, switch to "sk_live_..." when you're ready
# to accept real donations. Never commit your real key to git.
STRIPE_SECRET_KEY=

# Optional: only used as a fallback if Stripe can't detect your domain automatically.
# Set this to your real deployed URL once you have one, e.g. https://homelesshelp.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
